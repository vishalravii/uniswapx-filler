# ── RPC endpoints ──────────────────────────────────────────────────────────────
# HTTP RPC for staticCalls / quote requests (Alchemy/Infura/QuickNode recommended)
RPC_URL_ARBITRUM=https://arb-mainnet.g.alchemy.com/v2/YOUR_KEY

# WebSocket RPC for block-level subscriptions (same provider, ws endpoint)
RPC_WS_URL_ARBITRUM=wss://arb-mainnet.g.alchemy.com/v2/YOUR_KEY

# ── Filler wallet ───────────────────────────────────────────────────────────────
# Private key of the EOA that holds output tokens and submits fill transactions
# NEVER commit this value. Use a dedicated filler wallet, not your main wallet.
FILLER_PRIVATE_KEY=0xYOUR_PRIVATE_KEY

# ── Optional: private mempool RPC (reduces front-run risk) ─────────────────────
# Flashbots Protect (Arbitrum): https://rpc.flashbots.net/fast?hint=calldata
# Leave empty to use RPC_URL_ARBITRUM for submission
FLASHBOTS_RPC=https://rpc.flashbots.net/fast

# ── Trusted UniswapX reactor addresses (comma-separated, all on Arbitrum One) ──
# Verify each address on Arbiscan before running in production.
# ExclusiveDutchOrderReactor V1 (Dutch / ExclusiveDutch orders):
TRUSTED_REACTORS=0x1bd1aAdc9E230626C44a139d7E70d842749351eb

# ── Profitability thresholds ───────────────────────────────────────────────────
# Minimum net USD profit after gas to attempt a fill
MIN_PROFIT_USD=0.10

# ── Risk controls ──────────────────────────────────────────────────────────────
# Max total USD loss per day before the filler pauses for 1 hour
DAILY_LOSS_LIMIT_USD=50

# Max number of simultaneous unconfirmed fill transactions
MAX_CONCURRENT_FILLS=3

# Abort fills when Arbitrum base fee exceeds this (gwei)
MAX_GAS_GWEI=2

# ── Debug ──────────────────────────────────────────────────────────────────────
# Set to "true" to print DEBUG-level log lines to stdout
DEBUG=false
